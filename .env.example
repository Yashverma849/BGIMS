# ─── Required in production ───────────────────────────────────────────
# Session cookie encryption key. Must be 32+ characters.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Server runtime ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=4321
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────
# SQLite file path (default: ./.data/mmbgims.db). Migrations auto-run on
# first connection. For Postgres, set DATABASE_URL=postgres://… and swap
# the driver in src/lib/db/client.ts.
DATABASE_URL=./.data/mmbgims.db

# ─── Initial admin (used by `pnpm db:seed`) ───────────────────────────
ADMIN_EMAIL=director@mmbgims.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_NAME=Director
ADMIN_ROLE=Director

# ─── Email (optional) ─────────────────────────────────────────────────
# Resend API key. If unset, /api/enquiries logs instead of emailing.
RESEND_API_KEY=

# ─── Public client flags (PUBLIC_* exposed to the browser) ────────────
# Show the demo credentials block on /admin/login (dev only).
PUBLIC_SHOW_DEMO_CREDS=false
PUBLIC_ADMIN_DEMO_EMAIL=director@mmbgims.com
PUBLIC_ADMIN_DEMO_PWD=bgims2026
