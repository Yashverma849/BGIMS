# Toggle real API routes for enquiry + application submission.
# When false (default), submissions are stored in localStorage only.
# When true, submissions POST to /api/* and persist server-side.
PUBLIC_USE_SERVER_API=false

# Optional: Resend API key for transactional email confirmation on enquiries.
# Leave blank to skip email sending in dev.
RESEND_API_KEY=

# Admin demo credentials (used by client-mock auth adapter).
ADMIN_DEMO_EMAIL=director@mmbgims.com
ADMIN_DEMO_PWD=bgims2026
