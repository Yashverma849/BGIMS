# ─── Required in production ───────────────────────────────────────────
# Session cookie encryption key. Must be 32+ characters.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Database (libSQL — works file-based locally, Turso in prod) ──────
# Local default (no setup needed): file:./.data/mmbgims.db
# Turso (Vercel/Netlify/Cloudflare): libsql://<your-db>.turso.io
DATABASE_URL=
# Required when DATABASE_URL points at Turso. Get from `turso db tokens create`.
DATABASE_AUTH_TOKEN=

# ─── Server runtime (self-hosted Node only) ───────────────────────────
HOST=0.0.0.0
PORT=4321
NODE_ENV=production
SITE_URL=https://mmbgims.com

# ─── Initial admin (used by `pnpm db:seed`) ───────────────────────────
ADMIN_EMAIL=director@mmbgims.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_NAME=Director
ADMIN_ROLE=Director

# ─── Email (optional) ─────────────────────────────────────────────────
# Resend API key. If unset, /api/enquiries logs instead of emailing.
RESEND_API_KEY=

# ─── Public flags (PUBLIC_* exposed to the browser) ───────────────────
# Show the demo credentials block on /admin/login (dev only).
PUBLIC_SHOW_DEMO_CREDS=false
PUBLIC_ADMIN_DEMO_EMAIL=director@mmbgims.com
PUBLIC_ADMIN_DEMO_PWD=bgims2026
