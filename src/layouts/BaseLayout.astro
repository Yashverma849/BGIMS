---
/**
 * The single source of truth for <head>: fonts, design tokens, the base
 * stylesheet, favicon, SEO meta, OG tags, JSON-LD, and the always-on chrome
 * scripts (page loader, scroll progress, sticky nav, mobile menu, smooth
 * anchors, magnetic buttons, custom cursor, reveal-on-scroll).
 *
 * Pages set `title` / `description` / `noindex` via props; per-page scripts
 * are added through Astro's `<script>` blocks in the page itself.
 */
import '~styles/tokens.css';
import '~styles/main.css';
import '~styles/pages.css';
import { site } from '~lib/site';

interface Props {
  title?: string;
  description?: string;
  /** When true, sets robots noindex,nofollow (admin pages). */
  noindex?: boolean;
  /** Body class (used by admin pages to swap chrome). */
  bodyClass?: string;
  /** Suppress page loader / scroll progress / cursor (used by admin pages). */
  bare?: boolean;
}

const {
  title = `${site.name} — ${site.tagline}`,
  description = site.description,
  noindex = false,
  bodyClass = '',
  bare = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).toString();
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={site.name} />
  <meta property="og:locale" content="en_IN" />
  <meta property="og:image" content={new URL('/og.svg', Astro.site ?? site.url).toString()} />
  <meta property="og:image:type" content="image/svg+xml" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="theme-color" content="#0F0C0A" />
  <meta name="format-detection" content="telephone=no" />
  <meta name="generator" content={Astro.generator} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Italiana&family=Manrope:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  {isHome && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'EducationalOrganization',
      name: site.fullName,
      alternateName: site.name,
      url: site.url,
      foundingDate: String(site.established),
      address: {
        '@type': 'PostalAddress',
        streetAddress: `${site.address.line1}, ${site.address.line2}`,
        addressLocality: 'Mumbai',
        postalCode: '400008',
        addressRegion: 'Maharashtra',
        addressCountry: 'IN',
      },
      telephone: site.phones.primary.display,
      email: site.emails.admissions,
    })} />
  )}
</head>
<body class={bodyClass}>
  {!bare && (
    <>
      <div class="page-loader"><div class="page-loader__mark"><em>BG</em>IMS</div></div>
      <div class="scroll-progress"></div>
    </>
  )}

  <slot />

  <script>
    import '~scripts/boot';
    import '~scripts/reveal';
    import '~scripts/cursor';
  </script>
</body>
</html>
