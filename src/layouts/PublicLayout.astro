---
/**
 * The standard public chrome: BaseLayout + Nav + Footer. Page content goes
 * in the default slot.
 */
import BaseLayout from './BaseLayout.astro';
import Nav from '~components/nav/Nav.astro';
import Footer from '~components/nav/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  contactEmail?: string;
  hideNewsletter?: boolean;
  navTheme?: 'light' | 'dark';
}
const { title, description, contactEmail, hideNewsletter, navTheme = 'light' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav theme={navTheme} />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  <Footer contactEmail={contactEmail} hideNewsletter={hideNewsletter} />
</BaseLayout>
