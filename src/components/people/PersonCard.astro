---
import type { CollectionEntry } from 'astro:content';

const TONE_BG: Record<string, string> = {
  maroon: '#722325',
  teal: '#0F4C4C',
  'maroon-dark': '#3D0E10',
  'maroon-deep': '#3D0E10',
  'teal-mid': '#1A6B6B',
};

interface Props {
  person: CollectionEntry<'faculty'>;
  delay?: number;
}
const { person, delay } = Astro.props;
const p = person.data;
const bg = TONE_BG[p.portraitTone ?? 'maroon'] ?? '#722325';
const meta = p.role.includes(p.department) ? p.role : `${p.role} · ${p.department}`;
---

<article class="person reveal" tabindex="0" data-delay={delay}>
  <div class="person__card">
    <div class="person__portrait" style={`background:${bg};`}>
      <span class="person__initials">{p.initials}</span>
    </div>
    <div class="person__overlay">
      <div class="person__summary">
        <h4 class="person__name">{p.name}</h4>
        <p class="person__meta">{meta}</p>
      </div>
      <p class="person__bio">{p.bio}</p>
    </div>
  </div>
</article>
