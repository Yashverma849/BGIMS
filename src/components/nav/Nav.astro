---
/**
 * Top navigation. Active link is computed from `Astro.url.pathname` so we
 * never hard-code an "active" class per page.
 */
import { site } from '~lib/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string): boolean => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
};
---

<nav class="nav">
  <a href="/" class="nav__logo">
    <span class="nav__logo-mark">B</span>
    <span class="nav__logo-text">
      <span>MM BGIMS</span>
      <small>Est. 2002 · Mumbai</small>
    </span>
  </a>
  <ul class="nav__menu">
    {site.navMain.map((item) => (
      <li><a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a></li>
    ))}
  </ul>
  <div class="nav__cta">
    <a href="/apply" class={`btn btn--accent${isActive('/apply') ? ' active' : ''}`} data-magnetic>
      Apply <span class="arrow">→</span>
    </a>
    <button class="nav__hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
