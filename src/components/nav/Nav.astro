---
/**
 * Top navigation. Active link is computed from `Astro.url.pathname` so we
 * never hard-code an "active" class per page.
 */
import { site } from '~lib/site';

interface Props {
  theme?: 'light' | 'dark';
}
const { theme = 'light' } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string): boolean => {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
};
---

<nav class={`nav nav--theme-${theme}`}>
  <div class="nav-topbar">
    <div class="nav-topbar__inner">
      <div class="nav-topbar__left">
        <span>Approved by AICTE & Affiliated to the University of Mumbai</span>
        <span class="nav-topbar__sep">|</span>
        <span>Accredited With B++ Grade by NAAC</span>
        <span class="nav-topbar__sep">|</span>
        <span>Choice Code: 311310210</span>
      </div>
      <div class="nav-topbar__right">
        <a href="tel:+919619510513" class="nav-topbar__link">
          <svg class="nav-topbar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <span>+91-9619510513</span>
        </a>
        <a href="mailto:admission@mmbgims.com" class="nav-topbar__link">
          <svg class="nav-topbar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span>admission@mmbgims.com</span>
        </a>
      </div>
    </div>
  </div>

  <div class="nav__row">
    <a href="/" class="nav__logo">
      <span class="nav__logo-mark">B</span>
      <span class="nav__logo-text">
        <span>MM BGIMS</span>
        <small>Est. 2002 · Mumbai</small>
      </span>
    </a>
    <ul class="nav__menu">
      {site.navMain.map((item) => (
        <li><a href={item.href} class={isActive(item.href) ? 'active' : ''}>{item.label}</a></li>
      ))}
    </ul>
    <div class="nav__cta">
      <a href="/apply" class={`btn btn--accent${isActive('/apply') ? ' active' : ''}`} data-magnetic>
        Apply <span class="arrow">→</span>
      </a>
      <button class="nav__hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>
