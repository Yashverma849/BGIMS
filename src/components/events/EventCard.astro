---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '~lib/format';

interface Props {
  event: CollectionEntry<'events'>;
  index: number;
  delay?: number;
}
const { event, index, delay } = Astro.props;
const e = event.data;
const num = String(index + 1).padStart(2, '0');
---

<article class="ev-card reveal" data-cat={e.category} data-delay={delay}>
  <div class={`ev-card__visual tone-${e.visualTone}`}>
    <div class="ev-card__visual-num">№ {num}</div>
    <svg viewBox="0 0 100 100" set:html={e.iconPath} />
  </div>
  <div class="ev-card__body">
    <span class="ev-card__cat">{e.categoryLabel}</span>
    <h3>{e.title}</h3>
    <span class="ev-card__date">— {formatDate(e.date, { day: 'numeric', month: 'long', year: 'numeric' })}</span>
    <p class="ev-card__exc">{e.excerpt}</p>
    <span class="ev-card__cta">Read account →</span>
  </div>
</article>
