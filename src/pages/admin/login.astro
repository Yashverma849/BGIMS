---
import AdminLayout from '~layouts/AdminLayout.astro';
import { site } from '~lib/site';
const demoEmail = (import.meta.env.PUBLIC_ADMIN_DEMO_EMAIL as string) || 'director@mmbgims.com';
const demoPwd = (import.meta.env.PUBLIC_ADMIN_DEMO_PWD as string) || 'bgims2026';
---

<AdminLayout title="CMS · Sign in — MM BGIMS" bodyClass="login-body">
  <div class="login">
    <aside class="login__art">
      <a href="/" class="login__logo">
        <span class="nav__logo-mark">B</span>
        <span class="nav__logo-text">
          <span>{site.name}</span>
          <small>Est. 2002 · Mumbai</small>
        </span>
      </a>

      <div class="login__art-inner">
        <span class="eyebrow">— Content Management</span>
        <h1>Tend to <em class="italic-accent">the institute</em>.</h1>
        <p class="login__lede">A quiet workspace for the people who keep BGIMS — its pages, its programmes, its applications and its alumni — in good order.</p>

        <figure class="login__quote">
          <blockquote>"Whoever is careful in small things is rarely careless in large ones."</blockquote>
          <figcaption>— from a director's office, c. 2002</figcaption>
        </figure>
      </div>

      <svg class="login__ornament" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="loginDots" width="20" height="20" patternUnits="userSpaceOnUse">
            <circle cx="2" cy="2" r="1" fill="currentColor" opacity=".25"/>
          </pattern>
        </defs>
        <circle cx="200" cy="200" r="180" fill="none" stroke="currentColor" stroke-width=".5" opacity=".3"/>
        <circle cx="200" cy="200" r="120" fill="none" stroke="currentColor" stroke-width=".5" opacity=".4"/>
        <circle cx="200" cy="200" r="60" fill="none" stroke="currentColor" stroke-width=".5" opacity=".5"/>
        <rect x="50" y="50" width="300" height="300" fill="url(#loginDots)" opacity=".4"/>
      </svg>

      <small class="login__footer-note">A private interface. © 2026 MM BGIMS.</small>
    </aside>

    <main class="login__main">
      <div class="login__form-wrap">
        <span class="eyebrow">— Sign in</span>
        <h2>Welcome back, <em class="italic-accent">colleague</em>.</h2>
        <p class="login__sub">Use your institute credentials. SSO with Google Workspace coming in the autumn release.</p>

        <form class="login__form" id="loginForm">
          <div class="form-group">
            <label for="login-email">Email</label>
            <input type="email" id="login-email" placeholder="firstname.lastname@mmbgims.com" required value={demoEmail} />
          </div>
          <div class="form-group">
            <label for="login-password">Password</label>
            <input type="password" id="login-password" placeholder="Enter password" required value={demoPwd} />
            <button type="button" class="login__pwd-toggle" aria-label="Show password" id="pwdToggle">show</button>
          </div>
          <div class="login__row">
            <label class="login__remember"><input type="checkbox" checked /> Keep me signed in</label>
            <a href="#" class="login__forgot">Forgot password?</a>
          </div>
          <button type="submit" class="btn btn--dark btn--large btn--block" data-magnetic>
            Sign in <span class="arrow">→</span>
          </button>

          <p class="login__error" id="loginError" hidden>
            Those credentials don't match anything on record. Try <code>{demoEmail}</code> / <code>{demoPwd}</code>.
          </p>
        </form>

        <div class="login__demo">
          <strong>Demo credentials</strong>
          <p>Email · <code>{demoEmail}</code><br />Password · <code>{demoPwd}</code></p>
        </div>

        <p class="login__back"><a href="/">← Return to public website</a></p>
      </div>
    </main>
  </div>
</AdminLayout>

<script>
  import '~scripts/admin/login';
</script>
