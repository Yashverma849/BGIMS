---
import PublicLayout from '~layouts/PublicLayout.astro';
---

<PublicLayout
  title="Page not found — MM BGIMS"
  description="The page you're looking for can't be located. Return to the institute's home page."
>
  <section class="page-hero" style="min-height: 70vh; display: grid; place-items: center; text-align: center;">
    <div class="container-narrow">
      <span class="eyebrow reveal">— Error 404</span>
      <h1 class="reveal" data-delay="100" style="margin: 1.5rem 0 1rem;">
        A page <em class="italic-accent">misplaced</em>.
      </h1>
      <p class="page-hero__lede reveal" data-delay="200" style="margin: 0 auto 2.5rem;">
        We could not find what you were looking for. The link may be old, or the page may have moved. The home page is a good starting point.
      </p>
      <div class="reveal" data-delay="300" style="display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn btn--accent" data-magnetic>Return home <span class="arrow">→</span></a>
        <a href="/contact" class="btn btn--ghost">Tell us about it</a>
      </div>
    </div>
  </section>
</PublicLayout>
