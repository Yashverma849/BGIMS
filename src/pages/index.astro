---
import PublicLayout from '~layouts/PublicLayout.astro';
import ProgramCard from '~components/programmes/ProgramCard.astro';
import PersonCard from '~components/people/PersonCard.astro';
import CtaBanner from '~components/layout/CtaBanner.astro';
import { getCollection } from 'astro:content';
import { HOME_TESTIMONIALS } from '~lib/data/testimonials';
import { HOME_MARQUEE_RECRUITERS } from '~lib/data/recruiters';

const programmes = (await getCollection('programmes')).sort((a, b) => a.data.order - b.data.order);
const allFaculty = await getCollection('faculty');
const facultyFeatured = allFaculty
  .filter((f) => f.data.type === 'director' || f.data.type === 'core')
  .sort((a, b) => a.data.order - b.data.order);
const FACULTY_PREVIEW_LIMIT = 4;
const events = (await getCollection('events'))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 3);
const marquee = [...HOME_MARQUEE_RECRUITERS, ...HOME_MARQUEE_RECRUITERS];
---

<PublicLayout
  title="MM BGIMS — Where Heritage Meets Tomorrow's Leaders"
  description="Maratha Mandir's Babasaheb Gawde Institute of Management Studies — Mumbai's distinguished management school crafting principled leaders since 2002."
  navTheme="dark"
>
  <!-- HERO -->
  <header class="hero">
    <div class="hero__bg">
      <video autoplay loop muted playsinline class="hero__video">
        <source src="/hero.mp4" type="video/mp4" />
      </video>
      <div class="hero__pattern"></div>
      <div class="hero__particles"></div>
    </div>
    <div class="hero__content">
      <div class="hero__bottom reveal" data-delay="3">
        <p class="hero__lead">
          For over two decades, Maratha Mandir's Babasaheb Gawde Institute of Management Studies has shaped Mumbai's most distinguished minds in finance, strategy, and enterprise — pairing rigorous scholarship with the city's pulse for global commerce.
        </p>
        <div class="hero__cta">
          <a href="/programs" class="btn btn--accent" data-magnetic>Explore Programs <span class="arrow">→</span></a>
          <a href="/about" class="btn btn--ghost">Our Story</a>
        </div>
      </div>
    </div>

    <div class="ticker">
      <div class="ticker__track">
        <span>Affiliated to the University of Mumbai</span>
        <span>Approved by AICTE, New Delhi</span>
        <span>Accredited NAAC B<sup>++</sup></span>
        <span>Choice Code 311310210</span>
        <span>Member · AIMS</span>
        <span>2,000+ Alumni Worldwide</span>
        <span>23 Years of Excellence</span>
        <span>Affiliated to the University of Mumbai</span>
        <span>Approved by AICTE, New Delhi</span>
        <span>Accredited NAAC B<sup>++</sup></span>
        <span>Choice Code 311310210</span>
        <span>Member · AIMS</span>
        <span>2,000+ Alumni Worldwide</span>
        <span>23 Years of Excellence</span>
      </div>
    </div>
  </header>

  <!-- HERITAGE / FEATURE -->
  <section id="heritage">
    <div class="feature-grid">
        <div class="feature-img reveal">
          <div class="feature-img__inner" style="background-image: url(/heritage-campus.png);">
          </div>
          <span class="feature-img__caption">The Mumbai Central Campus</span>
        </div>

        <div class="reveal" data-delay="2">
          <span class="eyebrow">A Note on our Heritage</span>
          <h2 style="margin: 1.2rem 0 1.5rem;">
            A management school <em class="italic-accent" style="color: var(--accent);">cultivated</em>
            in the spirit of Mumbai's mercantile imagination.
          </h2>
          <p class="lead typewriter-text" style="margin-bottom: 1.5rem;">
            Founded under the aegis of the venerable <strong>Maratha Mandir Trust</strong>, MM BGIMS has, since its inception in 2002, occupied a singular position in the Indian management education landscape — close enough to Dalal Street to feel its tremors, distant enough from convention to think for itself.
          </p>
          <p class="typewriter-text">
            Our programs are taught by faculty drawn from boardrooms and seminar rooms in equal measure. Our students walk into Mumbai Central as candidates and leave as practitioners, prepared for the questions tomorrow has not yet asked.
          </p>
          <div style="display: flex; gap: 2rem; margin-top: 2.5rem; flex-wrap: wrap;">
            <a href="/about" class="link-underline">Read our story <span>→</span></a>
            <a href="/about#governing-body" class="link-underline">Governing body <span>→</span></a>
          </div>
        </div>
      </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="stats__grid">
      <div class="stat reveal">
        <div class="stat__number" data-count="2000"><span class="num">0</span><sup>+</sup></div>
        <div class="stat__label">Illustrious Alumni</div>
        <div class="stat__detail">Across six continents and every Fortune 500 industry.</div>
      </div>
      <div class="stat reveal" data-delay="1">
        <div class="stat__number" data-count="100"><span class="num">0</span><sup>%</sup></div>
        <div class="stat__label">Placement Assistance</div>
        <div class="stat__detail">Dedicated cell. Live since cohort one.</div>
      </div>
      <div class="stat reveal" data-delay="2">
        <div class="stat__number" data-count="50"><span class="num">0</span><sup>+</sup></div>
        <div class="stat__label">Industry Faculty</div>
        <div class="stat__detail">Practitioners who lecture; lecturers who practice.</div>
      </div>
      <div class="stat reveal" data-delay="3">
        <div class="stat__number" data-count="180"><span class="num">0</span><sup>+</sup></div>
        <div class="stat__label">Recruiting Partners</div>
        <div class="stat__detail">From Morgan Stanley to the Tata Group.</div>
      </div>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section id="programs">
    <div class="section-header reveal">
      <div>
        <h2 style="max-width: 35ch;">Four programs. Each <em class="italic-accent" style="color: var(--accent);">distinct</em>.<br>Each rigorous.</h2>
      </div>
      <a href="/programs" class="link-underline">View all programs <span>→</span></a>
    </div>

    <div class="programs__grid">
      {programmes.map((p, i) => (
        <ProgramCard programme={p} delay={i} />
      ))}
    </div>
  </section>

  <!-- DIRECTOR'S NOTE -->
  <section id="director-note" class="director-note">
    <div class="director-note__inner">
      <p class="director-note__label reveal">· A Word from the Director ·</p>
      <blockquote class="director-note__quote reveal" data-delay="1">
        "We do not <em class="italic-accent">teach</em> management here.<br>
        We <em class="italic-accent">cultivate</em> the temperament<br>that makes management <em class="italic-accent">possible</em>."
      </blockquote>
      <div class="director-note__cite reveal" data-delay="2">
        <strong>Dr. Vidya Hattangadi</strong>
        <span>Director, MM BGIMS</span>
      </div>
    </div>
  </section>

  <!-- FACULTY PREVIEW -->
  <section id="faculty-preview">
    <div class="section-header reveal">
      <div>
        <h2>Faculty who <em class="italic-accent" style="color: var(--accent);">read</em>,<br>and write what others read.</h2>
      </div>
      <a href="/faculty" class="link-underline">Meet the faculty <span>→</span></a>
    </div>

    <div class="people-grid faculty-grid-expand" data-faculty-expand data-faculty-limit={FACULTY_PREVIEW_LIMIT}>
      {facultyFeatured.map((p, i) => (
        <PersonCard person={p} delay={i} />
      ))}
    </div>

    {facultyFeatured.length > FACULTY_PREVIEW_LIMIT && (
      <div class="faculty-expand-actions">
        <button type="button" class="btn btn--ghost" data-faculty-expand-btn aria-expanded="false">
          Read more
        </button>
      </div>
    )}
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="testimonials__header reveal">
      <div class="testimonials__header-inner">
        <h2 class="testimonials__title typewriter-text">The voices of our alumni.</h2>
      </div>
      <nav class="testimonial-nav" aria-label="Testimonial slides">
        <button data-testimonial-prev aria-label="Previous">←</button>
        <button data-testimonial-next aria-label="Next">→</button>
      </nav>
    </div>

      {HOME_TESTIMONIALS.map((t) => {
        const [pre, post] = t.bodyEm
          ? t.body.split('{{em}}')
          : [t.body, ''];
        return (
          <div data-testimonial class="testimonial">
            <div class="testimonial__visual">
              <div class="testimonial__visual-mark">{t.initials}</div>
            </div>
            <div class="testimonial__content">
              <p class="testimonial__body">
                {pre}{t.bodyEm && <em>{t.bodyEm}</em>}{post}
              </p>
              <div class="testimonial__cite">
                <strong>{t.cite}</strong>
                <span>{t.citeMeta}</span>
              </div>
            </div>
          </div>
        );
      })}

  </section>

  <!-- RECRUITERS MARQUEE -->
  <section class="recruiters">
    <div class="recruiters__intro reveal">
      <h3>From Mumbai's <em class="italic-accent" style="color: var(--accent);">trading floors</em> to global capitals.</h3>
      <p>A few of the firms that have hired our graduates over the past 23 years.</p>
    </div>
    <div class="marquee">
      <div class="marquee__track">
        {marquee.map((name) => <span class="marquee__item">{name}</span>)}
      </div>
    </div>
  </section>

  <!-- EVENTS -->
  <section id="events">
    <div class="section-header reveal">
      <div>
        <h2>Recent <em class="italic-accent" style="color: var(--accent);">moments</em>.</h2>
      </div>
      <a href="/events" class="link-underline">All events & news <span>→</span></a>
    </div>

    <div class="events__grid">
      {events.map((ev, i) => (
        <a href="/events" class="event-link">
          <article class="event reveal" data-delay={i}>
            <div class="event__inner">
              <div class="event__date">
                <strong>{new Date(ev.data.date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' })}</strong>
                <span>{ev.data.categoryLabel}</span>
              </div>
              <h4 class="event__title">{ev.data.title}</h4>
              <p class="event__excerpt">{ev.data.excerpt}</p>
              <span class="event__cta">Read account <span>→</span></span>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>

  <CtaBanner
    title={`Admissions for the<br><em class="italic-accent">2026—2028</em> cohort<br>are now open.`}
    primaryHref="/apply"
    primaryLabel="Begin Application"
    secondaryHref="/admissions"
    secondaryLabel="Process & Eligibility"
    backgroundImage="/mba-bf-bg.png"
  />
</PublicLayout>

<script>
  import '~scripts/counters';
  import '~scripts/particles';
  import '~scripts/hero-words';
  import '~scripts/testimonial-slider';
</script>
