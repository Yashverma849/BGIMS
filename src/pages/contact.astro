---
import PublicLayout from '~layouts/PublicLayout.astro';
import { CONTACT_DESKS } from '~lib/data/contact';
---

<PublicLayout
  title="Contact — MM BGIMS"
  description="Reach the MM BGIMS admissions, placement and general offices. Visit us at Mumbai Central."
>
  <section class="section section--contact-form">
    <div class="container">
      <div class="contact-dual">
        <div class="contact-dual__form-card reveal">
          <h2 class="contact-dual__heading">
            Let's start a <em>conversation.</em>
          </h2>

          <form class="enquiry-form enquiry-form--panel" data-form="enquiry">
            <div class="form-row">
              <div class="form-group">
                <label for="enq-name">Full name <span aria-hidden="true">*</span></label>
                <input type="text" id="enq-name" name="name" required />
              </div>
              <div class="form-group">
                <label for="enq-email">Email address <span aria-hidden="true">*</span></label>
                <input type="email" id="enq-email" name="email" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="enq-phone">Mobile</label>
                <input type="tel" id="enq-phone" name="phone" placeholder="+91 " />
              </div>
              <div class="form-group">
                <label for="enq-prog">Programme of interest</label>
                <select id="enq-prog" name="programme">
                  <option value="">Select a programme</option>
                  <option>MBA · Banking &amp; Finance</option>
                  <option>MMS</option>
                  <option>BMS</option>
                  <option>Ph.D.</option>
                  <option>General enquiry</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="enq-msg">Your message <span aria-hidden="true">*</span></label>
              <textarea id="enq-msg" name="message" rows="5" placeholder="Programme, deadlines, campus visit — anything that helps us route you to the right desk." required></textarea>
            </div>
            <div class="form-group form-group--check">
              <input type="checkbox" id="enq-consent" name="consent" required />
              <label for="enq-consent">I consent to be contacted by MM BGIMS regarding this enquiry.</label>
            </div>
            <!-- Honeypot — humans don't see it; bots fill it; submission is rejected. -->
            <div class="hp-field" aria-hidden="true">
              <label>If you're a human, leave this empty
                <input type="text" name="company_field" tabindex="-1" autocomplete="off" />
              </label>
            </div>

            <button type="submit" class="btn btn--accent btn--large btn--block contact-dual__submit" data-magnetic>
              Send Message <span class="arrow">→</span>
            </button>
            <p class="form-success" data-form-success>Thank you. Your enquiry has been received. We'll respond within one working day.</p>
          </form>
        </div>

        <aside class="contact-dual__visual reveal" data-delay="100">
          <img
            src="/heritage-campus.png"
            alt="Maratha Mandir Annexe — MM BGIMS campus at Mumbai Central"
            loading="lazy"
            width="640"
            height="800"
          />
          <div class="contact-dual__visual-overlay">
            <span class="contact-dual__visual-eyebrow">MM BGIMS</span>
            <h3 class="contact-dual__visual-title">Principled leadership, Mumbai Central.</h3>
            <p class="contact-dual__visual-desc">
              Maratha Mandir Trust since 2002. Admissions, placements and general desks — replies within one working day.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="contact-desks">
        {CONTACT_DESKS.map((d, i) => (
          <div class="contact-desk reveal" data-delay={i * 100}>
            <span class="eyebrow">{d.numeral}</span>
            <h3>{d.title}</h3>
            <p>{d.blurb}</p>
            <div class="contact-desk__lines">
              <a href={`mailto:${d.email}`}>{d.email}</a>
              <a href={`tel:${d.phoneTel}`}>{d.phoneDisplay}</a>
              <small>{d.hours}</small>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</PublicLayout>

<script>
  import '~scripts/enquiry-form';
</script>
