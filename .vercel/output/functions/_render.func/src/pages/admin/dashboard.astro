              <span class="kpi-card__delta kpi-card__delta--up">+12%</span>
            </div>
            <strong class="kpi-card__num" id="kpiApps">0</strong>
            <p class="kpi-card__sub">received this admissions cycle</p>
            <svg class="kpi-card__sparkline" viewBox="0 0 100 30" preserveAspectRatio="none">
              <polyline points="0,22 12,18 25,20 38,12 50,15 62,8 75,10 88,5 100,7" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
