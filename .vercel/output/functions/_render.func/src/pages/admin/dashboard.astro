---
import AdminLayout from '~layouts/AdminLayout.astro';
import { site } from '~lib/site';
import { currentUser } from '~lib/auth/server';

export const prerender = false;

// Middleware has already verified the session before we get here, but
// fetching the user lets us prefill the sidebar on the first paint.
// Tolerate DB outages — the page still renders and JS will retry.
const user = await currentUser(Astro.cookies).catch(() => null);
const initial = (user?.email ?? 'D').charAt(0).toUpperCase();
const role = user?.role ?? 'Director';
const email = user?.email ?? 'director@mmbgims.com';
---

<AdminLayout title="CMS · Dashboard — MM BGIMS" bodyClass="cms-body">
  <div class="cms">
    <aside class="cms-sidebar">
      <a href="/" class="cms-sidebar__logo">
        <span class="nav__logo-mark">B</span>
        <span class="nav__logo-text">
          <span>{site.name}</span>
          <small>Content Management</small>
        </span>
      </a>

      <nav class="cms-nav">
        <span class="cms-nav__group">Workspace</span>
        <a href="#dashboard" class="cms-nav__link is-active" data-tab="dashboard">
          <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.4"/><rect x="14" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.4"/><rect x="3" y="14" width="7" height="7" stroke="currentColor" stroke-width="1.4"/><rect x="14" y="14" width="7" height="7" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Overview</span>
        </a>
        <a href="#applications" class="cms-nav__link" data-tab="applications">
          <svg viewBox="0 0 24 24" fill="none"><path d="M9 2h6l5 5v13a2 2 0 01-2 2H7a2 2 0 01-2-2V4a2 2 0 012-2h2z" stroke="currentColor" stroke-width="1.4"/><path d="M14 2v6h6M9 13h6M9 17h4" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Applications</span>
          <span class="cms-nav__badge" id="appCountBadge">0</span>
        </a>
        <a href="#enquiries" class="cms-nav__link" data-tab="enquiries">
          <svg viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Enquiries</span>
          <span class="cms-nav__badge" id="enqCountBadge">0</span>
        </a>
        <a href="#students" class="cms-nav__link" data-tab="students">
          <svg viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.4"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Students</span>
        </a>

        <span class="cms-nav__group">Content</span>
        <a href="#pages" class="cms-nav__link" data-tab="pages">
          <svg viewBox="0 0 24 24" fill="none"><rect x="4" y="4" width="16" height="16" stroke="currentColor" stroke-width="1.4"/><line x1="4" y1="9" x2="20" y2="9" stroke="currentColor" stroke-width="1.4"/><line x1="9" y1="9" x2="9" y2="20" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Pages</span>
        </a>
        <a href="#programs" class="cms-nav__link" data-tab="programs">
          <svg viewBox="0 0 24 24" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z" stroke="currentColor" stroke-width="1.4"/><path d="M6 12v5c3 3 9 3 12 0v-5" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Programmes</span>
        </a>
        <a href="#faculty" class="cms-nav__link" data-tab="faculty">
          <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.4"/><path d="M4 21v-1a8 8 0 0116 0v1" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Faculty</span>
        </a>
        <a href="#events" class="cms-nav__link" data-tab="events">
          <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="18" stroke="currentColor" stroke-width="1.4"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.4"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.4"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Events</span>
        </a>
        <a href="#testimonials" class="cms-nav__link" data-tab="testimonials">
          <svg viewBox="0 0 24 24" fill="none"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Testimonials</span>
        </a>

        <span class="cms-nav__group">Finance</span>
        <a href="#payments" class="cms-nav__link" data-tab="payments">
          <svg viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.4"/><line x1="2" y1="10" x2="22" y2="10" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Payments</span>
        </a>

        <span class="cms-nav__group">System</span>
        <a href="#settings" class="cms-nav__link" data-tab="settings">
          <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.4"/></svg>
          <span>Settings</span>
        </a>
      </nav>

      <div class="cms-sidebar__user">
        <div class="cms-user">
          <div class="cms-user__avatar" id="userAvatar">{initial}</div>
          <div class="cms-user__info">
            <strong id="userName">{role}</strong>
            <small id="userEmail">{email}</small>
          </div>
        </div>
        <button class="cms-user__signout" id="signOut">Sign out</button>
      </div>
    </aside>

    <main class="cms-main">
      <header class="cms-topbar">
        <div>
          <span class="eyebrow">— CMS</span>
          <h1 id="cmsTitle">Overview</h1>
        </div>
        <div class="cms-topbar__actions">
          <div class="cms-search">
