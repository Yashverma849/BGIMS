{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/dashboard\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/admin\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/applications\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/audit\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/content\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/enquiries\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/admin\\/seed-demo\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/applications\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/auth\\/login\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/auth\\/logout\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/auth\\/me\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/enquiries\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/health\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		},
		{
			"src": "/.*",
			"dest": "/404.html",
			"status": 404
		}
	]
}