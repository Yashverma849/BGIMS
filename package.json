{
  "name": "mmbgims-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MM BGIMS — Heritage Reimagined. Astro + TypeScript institutional website.",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "start": "node ./server.mjs",
    "build": "astro build",
    "preview": "node ./server.mjs",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.astro,.js --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,astro,css,md,mdx,json}\"",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "verify": "pnpm run check && pnpm run lint && pnpm run test:unit && pnpm run build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^3.1.9",
    "@astrojs/node": "^8.3.4",
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^4.16.18",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "vitest": "^2.1.4"
  }
}
