{
  "name": "mmbgims-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MM BGIMS — Heritage Reimagined. Astro + TypeScript institutional website.",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "start": "astro preview --host 127.0.0.1 --port 4321",
    "build": "astro build",
    "preview": "astro preview --host 127.0.0.1 --port 4321",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.astro,.js --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,astro,css,md,mdx,json}\"",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "verify": "pnpm run check && pnpm run lint && pnpm run test:unit && pnpm run build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^3.1.9",
    "@astrojs/node": "^8.3.4",
    "@astrojs/sitemap": "3.6.0",
    "@astrojs/vercel": "^7.8.2",
    "@libsql/client": "^0.17.3",
    "argon2": "^0.44.0",
    "astro": "^4.16.18",
    "drizzle-orm": "^0.45.2",
    "gsap": "^3.15.0",
    "iron-session": "^8.0.4",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "astro-eslint-parser": "^1.4.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.21.0",
    "vitest": "^2.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "sharp"
    ]
  }
}
