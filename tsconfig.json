{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "~components/*": ["src/components/*"],
      "~layouts/*": ["src/layouts/*"],
      "~lib/*": ["src/lib/*"],
      "~scripts/*": ["src/scripts/*"],
      "~styles/*": ["src/styles/*"]
    },
    "verbatimModuleSyntax": false,
    "jsx": "preserve",
    "types": ["astro/client"]
  },
  "include": ["src", ".astro/types.d.ts", "astro.config.mjs"],
  "exclude": ["dist", "node_modules", "_reference"]
}
